# Common reverse shell ports
alert tcp any any -> any 4444 (msg:"REVSHELL - Connection to port 4444"; metadata: tag revshell; sid:105001; rev:1;)
alert tcp any any -> any 9999 (msg:"REVSHELL - Connection to port 9999"; metadata: tag revshell; sid:105002; rev:1;)
alert tcp any any -> any 1337 (msg:"REVSHELL - Connection to port 1337"; metadata: tag revshell; sid:105003; rev:1;)
alert tcp any any -> any 4242 (msg:"REVSHELL - Connection to port 4242"; metadata: tag revshell; sid:105004; rev:1;)
alert tcp any any -> any 5555 (msg:"REVSHELL - Connection to port 5555"; metadata: tag revshell; sid:105005; rev:1;)
alert tcp any any -> any 8888 (msg:"REVSHELL - Connection to port 8888"; metadata: tag revshell; sid:105006; rev:1;)
alert tcp any any -> any 31337 (msg:"REVSHELL - Connection to port 31337"; metadata: tag revshell; sid:105007; rev:1;)

# Reverse shell payloads in HTTP
alert http any any -> any any (msg:"REVSHELL - bash -i redirect"; content:"bash"; content:"-i"; distance:0; within:10; content:"/dev/tcp"; distance:0; within:30; metadata: tag revshell; sid:105010; rev:1;)

alert http any any -> any any (msg:"REVSHELL - nc -e /bin/sh"; content:"nc"; content:"-e"; distance:0; within:10; content:"/bin/"; distance:0; within:20; metadata: tag revshell; sid:105011; rev:1;)

alert http any any -> any any (msg:"REVSHELL - ncat reverse shell"; content:"ncat"; metadata: tag revshell; sid:105012; rev:1;)

alert http any any -> any any (msg:"REVSHELL - python -c import socket"; content:"python"; content:"import"; distance:0; within:20; content:"socket"; distance:0; within:20; metadata: tag revshell; sid:105013; rev:1;)

alert http any any -> any any (msg:"REVSHELL - perl -e socket"; content:"perl"; content:"socket"; distance:0; within:30; metadata: tag revshell; sid:105014; rev:1;)

alert http any any -> any any (msg:"REVSHELL - ruby -rsocket"; content:"ruby"; content:"socket"; distance:0; within:20; metadata: tag revshell; sid:105015; rev:1;)

alert http any any -> any any (msg:"REVSHELL - mkfifo pipe pattern"; content:"mkfifo"; metadata: tag revshell; sid:105016; rev:1;)

alert http any any -> any any (msg:"REVSHELL - /dev/tcp/ pattern"; content:"/dev/tcp/"; metadata: tag revshell; sid:105017; rev:1;)

# Outbound shell activity on TCP (non-HTTP)
alert tcp any any -> any any (msg:"REVSHELL - Interactive shell banner (uid=)"; content:"uid="; content:"gid="; distance:0; within:30; metadata: tag revshell; sid:105020; rev:1;)


# =============================================================================
# WEBSHELL DETECTION
# =============================================================================

alert http any any -> any any (msg:"WEBSHELL - PHP system() in request"; content:"system("; nocase; metadata: tag webshell; sid:106001; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - PHP exec() in request"; content:"exec("; nocase; metadata: tag webshell; sid:106002; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - PHP passthru() in request"; content:"passthru("; nocase; metadata: tag webshell; sid:106003; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - PHP shell_exec() in request"; content:"shell_exec("; nocase; metadata: tag webshell; sid:106004; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - PHP eval() in request"; content:"eval("; nocase; metadata: tag webshell; sid:106005; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - PHP assert() in request"; content:"assert("; nocase; metadata: tag webshell; sid:106006; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - PHP proc_open() in request"; content:"proc_open("; nocase; metadata: tag webshell; sid:106007; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - cmd parameter pattern"; http_uri; pcre:"/[?&](cmd|command|exec|execute|run|shell|c|x)=/i"; metadata: tag webshell; sid:106008; rev:1;)

# Weevely (mentioned in wiki tools)
alert http any any -> any any (msg:"WEBSHELL - Weevely-like obfuscated PHP"; content:"base64_decode"; nocase; content:"eval"; nocase; distance:0; within:50; metadata: tag webshell; sid:106009; rev:1;)

# Python os.system / subprocess
alert http any any -> any any (msg:"WEBSHELL - Python os.system() in request"; content:"os.system"; metadata: tag webshell; sid:106010; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - Python subprocess in request"; content:"subprocess"; metadata: tag webshell; sid:106011; rev:1;)

alert http any any -> any any (msg:"WEBSHELL - Python os.popen() in request"; content:"os.popen"; metadata: tag webshell; sid:106012; rev:1;)


# =============================================================================
# DATA DESTRUCTION (Logical DoS - allowed but we want to detect it)
# =============================================================================

alert http any any -> any any (msg:"DESTRUCT - SQL DROP TABLE"; content:"drop"; nocase; content:"table"; nocase; distance:0; within:15; metadata: tag destruction; sid:107001; rev:1;)

alert http any any -> any any (msg:"DESTRUCT - SQL DROP DATABASE"; content:"drop"; nocase; content:"database"; nocase; distance:0; within:15; metadata: tag destruction; sid:107002; rev:1;)

alert http any any -> any any (msg:"DESTRUCT - SQL TRUNCATE TABLE"; content:"truncate"; nocase; content:"table"; nocase; distance:0; within:15; metadata: tag destruction; sid:107003; rev:1;)

alert http any any -> any any (msg:"DESTRUCT - SQL DELETE FROM (mass delete)"; content:"delete"; nocase; content:"from"; nocase; distance:0; within:15; metadata: tag destruction; sid:107004; rev:1;)

alert http any any -> any any (msg:"DESTRUCT - rm -rf command"; content:"rm"; content:"-rf"; distance:0; within:10; metadata: tag destruction; sid:107005; rev:1;)

alert http any any -> any any (msg:"DESTRUCT - rm -f command"; content:"rm"; content:"-f"; distance:0; within:10; metadata: tag destruction; sid:107006; rev:1;)

alert http any any -> any any (msg:"DESTRUCT - Docker stop/rm attempt"; pcre:"/docker\s+(stop|rm|kill)/i"; metadata: tag destruction; sid:107007; rev:1;)


