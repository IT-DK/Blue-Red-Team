# =============================================================================
# AUTHENTICATION / BRUTE FORCE INDICATORS
# =============================================================================

# These won't catch every brute force but flag suspicious patterns
alert http any any -> any any (msg:"AUTH - Login endpoint hit with POST"; content:"POST"; http_method; pcre:"/\/(login|signin|auth|authenticate|api\/login|api\/auth)/i"; http_uri; metadata: tag auth_attempt; sid:109001; rev:1;)

alert http any any -> any any (msg:"AUTH - Registration endpoint hit with POST"; content:"POST"; http_method; pcre:"/\/(register|signup|api\/register|api\/signup|create.?account)/i"; http_uri; metadata: tag registration; sid:109002; rev:1;)

# HTTP 401 (repeated = brute force)
alert http any any -> any any (msg:"AUTH - HTTP 401 Unauthorized response"; http.stat_code; content:"401"; metadata: tag auth_fail; sid:109003; rev:1;)


# =============================================================================
# DATABASE EXPLOITATION (Redis, PostgreSQL, MySQL)
# =============================================================================

# Redis commands in HTTP (Redis injection via SSRF or direct)
alert http any any -> any any (msg:"DB - Redis CONFIG SET"; content:"CONFIG"; nocase; content:"SET"; nocase; distance:0; within:10; metadata: tag redis; sid:110001; rev:1;)

alert http any any -> any any (msg:"DB - Redis EVAL (Lua exec)"; content:"EVAL"; pcre:"/EVAL\s+\"/i"; metadata: tag redis; sid:110002; rev:1;)

alert http any any -> any any (msg:"DB - Redis SLAVEOF/REPLICAOF"; pcre:"/(SLAVEOF|REPLICAOF)\s+\d/i"; metadata: tag redis; sid:110003; rev:1;)

alert http any any -> any any (msg:"DB - Redis FLUSHALL/FLUSHDB"; pcre:"/FLUSH(ALL|DB)/i"; metadata: tag redis; sid:110004; rev:1;)

# Redis on default port from external
alert tcp any any -> any 6379 (msg:"DB - Direct Redis connection attempt"; metadata: tag redis_direct; sid:110005; rev:1;)

# PostgreSQL on default port from external
alert tcp any any -> any 5432 (msg:"DB - Direct PostgreSQL connection attempt"; metadata: tag pg_direct; sid:110006; rev:1;)

# MySQL/MariaDB on default port from external
alert tcp any any -> any 3306 (msg:"DB - Direct MySQL/MariaDB connection attempt"; metadata: tag mysql_direct; sid:110007; rev:1;)

# PostgreSQL RCE patterns
alert http any any -> any any (msg:"DB - PostgreSQL COPY TO PROGRAM"; content:"copy"; nocase; content:"program"; nocase; distance:0; within:30; metadata: tag pg_rce; sid:110008; rev:1;)

alert http any any -> any any (msg:"DB - PostgreSQL lo_import/lo_export"; pcre:"/lo_(import|export)/i"; metadata: tag pg_rce; sid:110009; rev:1;)


