# =============================================================================
# OCF26 CyberLegion - Suricata Rules
# =============================================================================
# Tailored for Attack-Defence CTF on Debian 12 with Docker-based services.
# Tech stacks: Python, PHP, C/C++, Golang, Rust, JS, Java, Bash
# Databases:   MariaDB, PostgreSQL, Redis
# Servers:     Nginx, Apache, DNS
#
# IMPORTANT: These rules are DETECTION-ONLY (alert, not drop).
#            Blocking traffic risks SLA penalties.
#
# Deploy: Copy to /etc/suricata/rules/ocf26_rules.rules
#         Add to suricata.yaml: - /etc/suricata/rules/ocf26_rules.rules
#         Restart: systemctl restart suricata
#
# SID Ranges:
#   100xxx - Flag exfiltration
#   101xxx - SQL Injection
#   102xxx - Command Injection / RCE
#   103xxx - Path Traversal / LFI / RFI
#   104xxx - SSTI (Server-Side Template Injection)
#   105xxx - Reverse Shells & Backdoors
#   106xxx - Webshells
#   107xxx - Data Destruction (logical DoS)
#   108xxx - Deserialization Attacks
#   109xxx - Authentication Attacks
#   110xxx - Database Exploitation (Redis, PostgreSQL, MySQL)
#   111xxx - PHP-specific Attacks
#   112xxx - File Upload Attacks
#   113xxx - SSRF
#   114xxx - XXE
#   115xxx - DNS Attacks
#   116xxx - Reconnaissance
# =============================================================================


# =============================================================================
# FLAG EXFILTRATION DETECTION (HIGHEST PRIORITY)
# =============================================================================
# Flag format: [task]_[round]_[team]_[hex_signature]
# Example: 1_20_2_81e01028111406ab
# Flags may appear in HTTP responses (being stolen from us)

# Flag pattern in HTTP response body (someone is stealing our flag)
alert http any any -> any any (msg:"FLAG EXFIL - AD flag pattern in HTTP response"; content:"_"; http_server_body; pcre:"/\d{1,2}_\d{1,3}_\d{1,2}_[a-f0-9]{16}/Ri"; metadata: tag flag_exfil; sid:100001; rev:2;)

# Flag pattern in HTTP request (attacker sending flag somewhere, or in URI)
alert http any any -> any any (msg:"FLAG EXFIL - AD flag pattern in HTTP request"; content:"_"; http_client_body; pcre:"/\d{1,2}_\d{1,3}_\d{1,2}_[a-f0-9]{16}/Ri"; metadata: tag flag_exfil; sid:100002; rev:2;)

# Flag pattern in HTTP URI
alert http any any -> any any (msg:"FLAG EXFIL - AD flag in URI"; content:"_"; http_uri; pcre:"/\d{1,2}_\d{1,3}_\d{1,2}_[a-f0-9]{16}/Ri"; metadata: tag flag_exfil; sid:100003; rev:2;)

# Base64 detection: common B64 patterns for flag-like strings
# (We can't match all B64 but we can match suspicious long b64 in responses)
alert http any any -> any any (msg:"FLAG EXFIL - Possible base64 encoded data in response"; content:"=="; http_server_body; pcre:"/[A-Za-z0-9+\/]{20,}={0,2}/R"; metadata: tag flag_exfil_b64; sid:100004; rev:1;)

# Flag in raw TCP stream (non-HTTP exfiltration)
alert tcp any any -> any any (msg:"FLAG EXFIL - AD flag pattern in TCP stream"; pcre:"/\d{1,2}_\d{1,3}_\d{1,2}_[a-f0-9]{16}/"; metadata: tag flag_exfil_tcp; sid:100005; rev:1;)


# =============================================================================
# SQL INJECTION
# =============================================================================

# --- Generic / Boolean-based ---
alert http any any -> any any (msg:"SQLi - OR 1=1 variant"; content:"or"; nocase; pcre:"/[\s'\"]+or[\s'\"]+['\"]?\d+['\"]?\s*=\s*['\"]?\d+/i"; metadata: tag sqli; sid:101001; rev:2;)

alert http any any -> any any (msg:"SQLi - AND 1=1 boolean test"; pcre:"/[\s'\"]+and[\s'\"]+['\"]?\d+['\"]?\s*=\s*['\"]?\d+/i"; metadata: tag sqli; sid:101002; rev:1;)

# --- UNION-based ---
alert http any any -> any any (msg:"SQLi - UNION SELECT"; content:"union"; nocase; content:"select"; nocase; distance:0; within:20; metadata: tag sqli; sid:101003; rev:2;)

alert http any any -> any any (msg:"SQLi - UNION ALL SELECT"; content:"union"; nocase; content:"all"; nocase; distance:0; within:10; content:"select"; nocase; distance:0; within:15; metadata: tag sqli; sid:101004; rev:1;)

# --- Time-based blind ---
alert http any any -> any any (msg:"SQLi - SLEEP() time-based blind (MySQL/MariaDB)"; content:"sleep"; nocase; content:"("; distance:0; within:5; metadata: tag sqli_blind; sid:101005; rev:1;)

alert http any any -> any any (msg:"SQLi - BENCHMARK() time-based blind (MySQL)"; content:"benchmark"; nocase; content:"("; distance:0; within:5; metadata: tag sqli_blind; sid:101006; rev:1;)

alert http any any -> any any (msg:"SQLi - pg_sleep() time-based blind (PostgreSQL)"; content:"pg_sleep"; nocase; metadata: tag sqli_blind; sid:101007; rev:1;)

alert http any any -> any any (msg:"SQLi - WAITFOR DELAY"; content:"waitfor"; nocase; content:"delay"; nocase; distance:0; within:15; metadata: tag sqli_blind; sid:101008; rev:1;)

# --- Error-based ---
alert http any any -> any any (msg:"SQLi - extractvalue() error-based"; content:"extractvalue"; nocase; metadata: tag sqli; sid:101009; rev:1;)

alert http any any -> any any (msg:"SQLi - updatexml() error-based"; content:"updatexml"; nocase; metadata: tag sqli; sid:101010; rev:1;)

# --- Stacked queries ---
alert http any any -> any any (msg:"SQLi - Semicolon stacked query attempt"; http_uri; pcre:"/[';]\s*(select|insert|update|delete|drop|alter|create|exec|union)/i"; metadata: tag sqli_stacked; sid:101011; rev:1;)

# --- Comment-based evasion ---
alert http any any -> any any (msg:"SQLi - Comment evasion /**/ in URI"; content:"/*"; http_uri; content:"*/"; http_uri; distance:0; metadata: tag sqli_evasion; sid:101012; rev:1;)

# --- PostgreSQL specific ---
alert http any any -> any any (msg:"SQLi - PostgreSQL COPY TO/FROM"; content:"copy"; nocase; pcre:"/copy\s+.+\s+(to|from)\s+/i"; metadata: tag sqli_pg; sid:101013; rev:1;)

alert http any any -> any any (msg:"SQLi - PostgreSQL dollar-quoting"; content:"$$"; metadata: tag sqli_pg; sid:101014; rev:1;)

alert http any any -> any any (msg:"SQLi - PostgreSQL string_agg/array_agg"; pcre:"/(string_agg|array_agg)\s*\(/i"; metadata: tag sqli_pg; sid:101015; rev:1;)

# --- MySQL/MariaDB specific ---
alert http any any -> any any (msg:"SQLi - MySQL INTO OUTFILE"; content:"into"; nocase; content:"outfile"; nocase; distance:0; within:20; metadata: tag sqli_mysql; sid:101016; rev:1;)

alert http any any -> any any (msg:"SQLi - MySQL LOAD_FILE()"; content:"load_file"; nocase; metadata: tag sqli_mysql; sid:101017; rev:1;)

alert http any any -> any any (msg:"SQLi - MySQL information_schema"; content:"information_schema"; nocase; metadata: tag sqli_mysql; sid:101018; rev:1;)


# =============================================================================
# COMMAND INJECTION / RCE
# =============================================================================

# --- Shell metacharacters in URI ---
alert http any any -> any any (msg:"CMDi - Semicolon in URI"; content:"%3b"; nocase; http_uri; metadata: tag cmdi; sid:102001; rev:1;)

alert http any any -> any any (msg:"CMDi - Pipe in URI (encoded)"; content:"%7c"; nocase; http_uri; metadata: tag cmdi; sid:102002; rev:1;)

alert http any any -> any any (msg:"CMDi - Backtick execution in URI"; content:"%60"; http_uri; metadata: tag cmdi; sid:102003; rev:1;)

alert http any any -> any any (msg:"CMDi - $() subshell in request"; content:"$("; metadata: tag cmdi; sid:102004; rev:1;)

alert http any any -> any any (msg:"CMDi - Backtick command substitution"; content:"`"; pcre:"/`.+`/"; metadata: tag cmdi; sid:102005; rev:1;)

# --- Known dangerous commands ---
alert http any any -> any any (msg:"CMDi - /bin/sh invocation"; content:"/bin/sh"; nocase; metadata: tag cmdi; sid:102006; rev:1;)

alert http any any -> any any (msg:"CMDi - /bin/bash invocation"; content:"/bin/bash"; nocase; metadata: tag cmdi; sid:102007; rev:1;)

alert http any any -> any any (msg:"CMDi - wget remote download"; content:"wget"; nocase; pcre:"/wget\s+https?:\/\//i"; metadata: tag cmdi; sid:102008; rev:1;)

alert http any any -> any any (msg:"CMDi - curl remote download"; content:"curl"; nocase; pcre:"/curl\s+(-[a-zA-Z]+\s+)*https?:\/\//i"; metadata: tag cmdi; sid:102009; rev:1;)

alert http any any -> any any (msg:"CMDi - cat /etc/passwd"; content:"cat"; nocase; content:"/etc/passwd"; distance:0; within:30; metadata: tag cmdi; sid:102010; rev:1;)

alert http any any -> any any (msg:"CMDi - id command execution"; pcre:"/[\s;&|`]id[\s;&|`$]/"; metadata: tag cmdi; sid:102011; rev:1;)

alert http any any -> any any (msg:"CMDi - whoami command"; content:"whoami"; nocase; metadata: tag cmdi; sid:102012; rev:1;)

alert http any any -> any any (msg:"CMDi - uname command"; pcre:"/[\s;&|`]uname[\s;&|`$-]/"; metadata: tag cmdi; sid:102013; rev:1;)

# --- Newline injection (HTTP header/command splitting) ---
alert http any any -> any any (msg:"CMDi - Newline injection %0a"; content:"%0a"; nocase; http_uri; metadata: tag cmdi; sid:102014; rev:1;)

alert http any any -> any any (msg:"CMDi - Carriage return injection %0d"; content:"%0d"; nocase; http_uri; metadata: tag cmdi; sid:102015; rev:1;)


# =============================================================================
# PATH TRAVERSAL / LFI / RFI
# =============================================================================

alert http any any -> any any (msg:"LFI - Path traversal ../"; content:"../"; http_uri; metadata: tag path_traversal; sid:103001; rev:1;)

alert http any any -> any any (msg:"LFI - Path traversal ..\\"; content:"..\\"; http_uri; metadata: tag path_traversal; sid:103002; rev:1;)

# URL-encoded variants
alert http any any -> any any (msg:"LFI - Encoded traversal %2e%2e%2f"; content:"%2e%2e%2f"; nocase; http_uri; metadata: tag path_traversal; sid:103003; rev:1;)

alert http any any -> any any (msg:"LFI - Double-encoded traversal %252e"; content:"%252e"; nocase; http_uri; metadata: tag path_traversal; sid:103004; rev:1;)

# Target files
alert http any any -> any any (msg:"LFI - /etc/passwd access"; content:"/etc/passwd"; http_uri; metadata: tag lfi; sid:103005; rev:1;)

alert http any any -> any any (msg:"LFI - /etc/shadow access"; content:"/etc/shadow"; http_uri; metadata: tag lfi; sid:103006; rev:1;)

alert http any any -> any any (msg:"LFI - /proc/self/environ access"; content:"/proc/self"; http_uri; metadata: tag lfi; sid:103007; rev:1;)

alert http any any -> any any (msg:"LFI - .env file access"; content:".env"; http_uri; metadata: tag lfi; sid:103008; rev:1;)

alert http any any -> any any (msg:"LFI - docker-compose.yml access"; content:"docker-compose"; http_uri; metadata: tag lfi; sid:103009; rev:1;)

# PHP wrappers
alert http any any -> any any (msg:"LFI - php://filter wrapper"; content:"php://filter"; nocase; http_uri; metadata: tag lfi_php; sid:103010; rev:1;)

alert http any any -> any any (msg:"LFI - php://input wrapper"; content:"php://input"; nocase; http_uri; metadata: tag lfi_php; sid:103011; rev:1;)

alert http any any -> any any (msg:"RFI - data:// wrapper"; content:"data://"; nocase; http_uri; metadata: tag rfi; sid:103012; rev:1;)

alert http any any -> any any (msg:"RFI - expect:// wrapper"; content:"expect://"; nocase; http_uri; metadata: tag rfi; sid:103013; rev:1;)

# Null byte (old PHP versions)
alert http any any -> any any (msg:"LFI - Null byte %00 in URI"; content:"%00"; http_uri; metadata: tag lfi; sid:103014; rev:1;)


# =============================================================================
# SSTI (Server-Side Template Injection)
# =============================================================================

# Jinja2 / Python
alert http any any -> any any (msg:"SSTI - Jinja2 {{ expression }}"; content:"{{"; metadata: tag ssti; sid:104001; rev:1;)

alert http any any -> any any (msg:"SSTI - Jinja2 __class__ probe"; content:"__class__"; nocase; metadata: tag ssti; sid:104002; rev:1;)

alert http any any -> any any (msg:"SSTI - Jinja2 __mro__ probe"; content:"__mro__"; nocase; metadata: tag ssti; sid:104003; rev:1;)

alert http any any -> any any (msg:"SSTI - Jinja2 __subclasses__"; content:"__subclasses__"; nocase; metadata: tag ssti; sid:104004; rev:1;)

alert http any any -> any any (msg:"SSTI - Jinja2 __globals__"; content:"__globals__"; nocase; metadata: tag ssti; sid:104005; rev:1;)

alert http any any -> any any (msg:"SSTI - Jinja2 __builtins__"; content:"__builtins__"; nocase; metadata: tag ssti; sid:104006; rev:1;)

alert http any any -> any any (msg:"SSTI - Jinja2 config.items()"; content:"config"; content:"items"; distance:0; within:20; metadata: tag ssti; sid:104007; rev:1;)

# Twig / PHP template
alert http any any -> any any (msg:"SSTI - Twig {{_self.env}}"; content:"_self.env"; metadata: tag ssti; sid:104008; rev:1;)

# Generic math probe (7*7=49, 7*191, etc.)
alert http any any -> any any (msg:"SSTI - Math probe {{7*7}}"; content:"{{7*7}}"; metadata: tag ssti; sid:104009; rev:1;)

alert http any any -> any any (msg:"SSTI - Math probe ${7*7}"; content:"${7*7}"; metadata: tag ssti; sid:104010; rev:1;)

# Java/Freemarker
alert http any any -> any any (msg:"SSTI - Freemarker <#assign>"; content:"<#assign"; nocase; metadata: tag ssti; sid:104011; rev:1;)

# Expression Language (Java)
alert http any any -> any any (msg:"SSTI - Java EL ${Runtime}"; content:"Runtime"; content:"getRuntime"; distance:0; within:30; metadata: tag ssti; sid:104012; rev:1;)


